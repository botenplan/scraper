name: MPET Bot Scraper

on:
  schedule:
    - cron: '*/30 * * * *'
  workflow_dispatch:

permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Python setup
        uses: actions/setup-python@v5
        with:
          python-version: '3.9'

      - name: Installatie
        run: pip install requests beautifulsoup4

      - name: Run
        run: python scraper.py

      - name: Opslaan naar GitHub
        run: |
          git config --global user.name "MPET-Bot"
          git config --global user.email "bot@mpet.com"
          git add mpet_planning.json
          git commit -m "Planning update" || exit 0
          git push origin main
